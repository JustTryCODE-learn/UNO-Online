  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'House Rules (7 & 0 Mechanics)


    The 7 Rule (Swap): When you play a
    7, you choose any opponent and trade hands with them.


    The 0 Rule (Rotate):
    When a 0 is played, everyone passes their hand to the next player in the current
    direction.


    Stacking: If a Draw card is played on you, you can play another
    Draw card to "stack" the penalty for the next person!'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
